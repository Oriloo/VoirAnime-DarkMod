{
  "manifest_version": 3,
  "name": "VoirAnime - DarkMod : streaming animes",
  "description": "Thème sombre et plus encore, pour l'ensemble du site \"voir-anime.to\" (VA).",
  "version": "2.1.3",
  "author": "Orilo",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "scripting",
    "storage"
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_popup": "modal/popup.html",
    "default_title": "VoirAnime DarkMod"
  },
  "host_permissions": [
    "*://*.voir-anime.to/*"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "versions/v200/*.css",
        "versions/v120/*.css"
      ],
      "matches": ["*://*.voir-anime.to/*"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["*://*.voir-anime.to/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "content_security_policy": {
    "extension_pages": "default-src 'self'; style-src 'self';"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "voiranime-darkmod2@orilo",
      "strict_min_version": "109.0"
    }
  }
}
